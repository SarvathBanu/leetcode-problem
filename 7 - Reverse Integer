class Solution:
    def reverse(self, x: int) -> int:

        sign = 1

        if x < 0:
            sign = -1
            x = -x

        reverse = 0

        while x > 0:
            rem = x % 10
            reverse = reverse * 10 + rem
            x = x // 10

        reverse = reverse * sign

        if reverse < -2147483648 or reverse > 2147483647:
            return 0

        return reverse
